<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
    <PackageId>HPD-RAG.Extensions</PackageId>
    <Description>DI wiring extensions for HPD-RAG (AddHPDMrag()).</Description>
    <PackageTags>rag;di;extensions;hpd</PackageTags>
    <RootNamespace>HPD-RAG.Extensions</RootNamespace>
    <AssemblyName>HPD-RAG.Extensions</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\HPD-RAG.Core\HPD-RAG.Core.csproj" />
