<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Inherits TargetFrameworks from Directory.Build.props: net10.0;net9.0;net8.0 -->
    <RootNamespace>HPD-RAG.Evaluation</RootNamespace>
    <AssemblyName>HPD-RAG.Evaluation</AssemblyName>
    <IsPackable>true</IsPackable>
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
    <PackageId>HPD-RAG.Evaluation</PackageId>
    <Description>Evaluation handler catalog for HPD-RAG.</Description>
    <PackageTags>rag;modular-rag;ai;llm;evaluation;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\HPD-RAG.Core\HPD-RAG.Core.csproj" />
    <ProjectReference Include="..\..\shared\HPD-Graph\HPD-Graph.Core\HPD-Graph.Core.csproj" />
    <ProjectReference Include="..\..\shared\HPD-Graph\HPD-Graph.SourceGenerator\HPD-Graph.SourceGenerator.csproj">
      <OutputItemType>Analyzer</OutputItemType>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <!--
      Pin to 9.10.0 — already present in the local NuGet package cache.
      DependencyInjection.Abstractions is NOT listed here; HPD-RAG.Core
      already pulls 10.0.3, and repeating a lower version causes NU1605.
    -->
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.3.0" />
    <PackageReference Include="Microsoft.Extensions.AI.Evaluation" Version="10.3.0" />
    <PackageReference Include="Microsoft.Extensions.AI.Evaluation.Quality" Version="10.3.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.3" />
  </ItemGroup>
</Project>
