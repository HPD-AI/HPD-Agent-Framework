<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Inherits TargetFrameworks from Directory.Build.props: net10.0;net9.0;net8.0 -->
    <RootNamespace>HPD-RAG.Pipeline</RootNamespace>
    <AssemblyName>HPD-RAG.Pipeline</AssemblyName>
    <IsPackable>true</IsPackable>
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
    <PackageId>HPD-RAG.Pipeline</PackageId>
    <Description>MragPipeline fluent builder and typed pipeline instances for HPD-RAG.</Description>
    <PackageTags>rag;pipeline;hpd</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <!-- Sibling MRAG projects (all in dotnet/src/HPD-RAG/) -->
    <ProjectReference Include="..\HPD-RAG.Core\HPD-RAG.Core.csproj" />
    <ProjectReference Include="..\HPD-RAG.Ingestion\HPD-RAG.Ingestion.csproj" />
    <ProjectReference Include="..\HPD-RAG.Retrieval\HPD-RAG.Retrieval.csproj" />
    <ProjectReference Include="..\HPD-RAG.Evaluation\HPD-RAG.Evaluation.csproj" />
    <!-- HPD-Graph.Core: dotnet/src/shared/HPD-Graph/HPD-Graph.Core/ -->
    <ProjectReference Include="..\..\shared\HPD-Graph\HPD-Graph.Core\HPD-Graph.Core.csproj" />
    <!-- HPD-Events: dotnet/src/shared/HPD-Events/ -->
    <ProjectReference Include="..\..\shared\HPD-Events\HPD-Events.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.3" />
  </ItemGroup>
</Project>
