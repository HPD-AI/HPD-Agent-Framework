<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Inherits TargetFrameworks from Directory.Build.props: net10.0;net9.0;net8.0 -->
    <IsPackable>true</IsPackable>
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
    <PackageId>HPD-RAG.EmbeddingProviders.OnnxRuntime</PackageId>
    <Description>ONNX Runtime embedding provider for HPD-RAG. Runs embedding models locally via Microsoft.Extensions.AI.Onnx.</Description>
    <PackageTags>rag;embedding;onnx;local</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\HPD-RAG.Core\HPD-RAG.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.*" />
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.3.0" />
  </ItemGroup>
</Project>
