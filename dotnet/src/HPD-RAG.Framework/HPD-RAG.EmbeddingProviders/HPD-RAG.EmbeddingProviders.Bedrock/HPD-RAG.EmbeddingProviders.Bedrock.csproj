<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Inherits TargetFrameworks from Directory.Build.props: net10.0;net9.0;net8.0 -->
    <IsPackable>true</IsPackable>
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
    <PackageId>HPD-RAG.EmbeddingProviders.Bedrock</PackageId>
    <Description>AWS Bedrock embedding provider for HPD-RAG.</Description>
    <PackageTags>rag;embedding;aws;bedrock</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\HPD-RAG.Core\HPD-RAG.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="AWSSDK.BedrockRuntime" Version="4.*" />
    <PackageReference Include="AWSSDK.Core" Version="4.*" />
    <PackageReference Include="AWSSDK.Extensions.Bedrock.MEAI" Version="4.*" />
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.3.0" />
  </ItemGroup>
</Project>
