<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Inherits TargetFrameworks from Directory.Build.props: net10.0;net9.0;net8.0 -->
    <RootNamespace>HPD-RAG.Retrieval</RootNamespace>
    <AssemblyName>HPD-RAG.Retrieval</AssemblyName>
    <IsPackable>true</IsPackable>
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
    <PackageId>HPD-RAG.Retrieval</PackageId>
    <Description>Retrieval handler catalog for HPD-RAG.</Description>
    <PackageTags>rag;modular-rag;ai;llm;retrieval;vector-search;graph;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>HPD-RAG.Handlers.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\HPD-RAG.Core\HPD-RAG.Core.csproj" />
    <ProjectReference Include="..\..\shared\HPD-Graph\HPD-Graph.Core\HPD-Graph.Core.csproj" />
    <ProjectReference Include="..\..\shared\HPD-Graph\HPD-Graph.SourceGenerator\HPD-Graph.SourceGenerator.csproj">
      <OutputItemType>Analyzer</OutputItemType>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.3.0" />
    <PackageReference Include="Microsoft.Extensions.VectorData.Abstractions" Version="10.0.1" />
  </ItemGroup>
</Project>
