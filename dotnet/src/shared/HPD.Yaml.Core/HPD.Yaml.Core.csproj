<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Inherits TargetFrameworks from Directory.Build.props: net10.0;net9.0;net8.0 -->
    <RootNamespace>HPD.Yaml.Core</RootNamespace>
    <AssemblyName>HPD.Yaml.Core</AssemblyName>
    <IsPackable>true</IsPackable>

    <!-- Native AOT Configuration -->
    <IsAotCompatible>true</IsAotCompatible>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>

    <!-- Package metadata -->
    <PackageId>HPD-Agent.Yaml.Core</PackageId>
    <Description>Shared YAML serialization converters for the HPD ecosystem. Provides TimeSpan, JsonElement, and enum dictionary key converters for YamlDotNet. Zero domain dependencies.</Description>
    <PackageTags>yaml;serialization;converters;yamldotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
  </ItemGroup>

</Project>
