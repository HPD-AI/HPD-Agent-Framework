<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TargetFrameworks></TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>HPD.Auth.Sample</RootNamespace>
    <AssemblyName>HPD.Auth.Sample</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <!-- Meta-package: AddHPDAuth, UseHPDAuth, MapHPDAuthEndpoints -->
