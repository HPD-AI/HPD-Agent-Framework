    <ProjectReference Include="../../src/HPD.Auth.Authentication/HPD.Auth.Authentication.csproj" />
    <ProjectReference Include="../../src/HPD.Auth.Audit/HPD.Auth.Audit.csproj" />
    <ProjectReference Include="../../src/HPD.Auth.Authorization/HPD.Auth.Authorization.csproj" />
    <ProjectReference Include="../../src/HPD.Auth.TwoFactor/HPD.Auth.TwoFactor.csproj" />
    <ProjectReference Include="../../src/HPD.Auth.Admin/HPD.Auth.Admin.csproj" />
  </ItemGroup>
</Project>
